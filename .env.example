# ============================================================
# XNK - Environment Variables
# Đây là file MẪU. Copy thành .env trước khi chạy:
#   cp .env.example .env
#
# File .env KHÔNG được commit lên Git (đã có trong .gitignore)
# Khi deploy K8s: các giá trị này được inject qua ConfigMap + Secret
# ============================================================

# ── Database ──────────────────────────────────────────────────
DB_ROOT_PASSWORD=root
DB_USERNAME=xnk
DB_PASSWORD=xnk@Dev
DB_PORT=3306

# ── JWT ───────────────────────────────────────────────────────
# Tối thiểu 32 ký tự, đổi thành giá trị ngẫu nhiên khi production
# openssl rand -hex 32
JWT_SECRET=6315bda6adba581f6895708b5d100a74f55ee55d67f35a80243945d630067563
JWT_EXPIRATION_MS=86400000

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
