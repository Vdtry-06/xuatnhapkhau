# ============================================================
# XNK Frontend - Environment Configuration
# Copy file này thành .env.local để dev hoặc .env.production để build
# Khi deploy K8s: inject qua ConfigMap → env trong container
# ============================================================

# API Gateway URL - tất cả request đều đi qua đây
REACT_APP_API_BASE_URL=http://localhost:8080

# App info
REACT_APP_APP_NAME=XNK Portal
REACT_APP_VERSION=1.0.0
